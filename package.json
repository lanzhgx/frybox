{
  "name": "frybox",
  "version": "1.0.0",
  "description": "Terminal app built for Claude Code sessions — named, colored, obvious",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "rebuild": "electron-rebuild",
    "postinstall": "electron-rebuild",
    "dist": "electron-builder --mac",
    "dist:dir": "electron-builder --mac --dir"
  },
  "dependencies": {
    "node-pty": "^1.1.0",
    "xterm": "^5.3.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0"
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9"
  },
  "build": {
    "appId": "com.frybox.app",
    "productName": "Frybox",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64"]
        }
      ]
    },
    "files": [
      "main.js",
      "renderer/**/*",
      "node_modules/**/*",
      "!node_modules/*/{CHANGELOG.md,README.md,readme.md,LICENSE,license}",
      "!node_modules/.cache/**/*"
    ],
    "dmg": {
      "title": "Frybox",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    }
  }
}
